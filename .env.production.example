# ============================================================
# AWS EC2 Production Environment — backend/.env
# Copy this file: cp .env.production.example backend/.env
# Then fill in all real values before deploying.
# ============================================================

# Django core
SECRET_KEY=change-me-use-a-long-random-string-50-chars-min
DEBUG=False
ALLOWED_HOSTS=51.20.91.11,yourdomain.com,www.yourdomain.com
DJANGO_SETTINGS_MODULE=config.settings.production

# Database (matches Docker Compose service name 'db')
DB_NAME=cloth_by_afs
DB_USER=postgres
DB_PASSWORD=use-a-strong-password-here
DB_HOST=db
DB_PORT=5432

# JWT token lifetimes
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# CORS & CSRF
# Add both http (IP) and https (domain) origins
CORS_ALLOWED_ORIGINS=http://51.20.91.11,https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=http://51.20.91.11,https://yourdomain.com,https://www.yourdomain.com

# Email (Gmail SMTP — use an App Password, not your login password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=Cloths by ASF <your@gmail.com>

# Frontend URL (used in email links etc.)
FRONTEND_URL=http://51.20.91.11

# Stripe (use live keys in production)
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Media storage — set USE_S3=True to store uploads in an S3 bucket
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=cloths-by-asf-media
# AWS_S3_REGION_NAME=eu-north-1

# SSL — set True ONLY after Nginx + Certbot HTTPS is working
SECURE_SSL_REDIRECT=False

# Logging level (WARNING | INFO | DEBUG)
DJANGO_LOG_LEVEL=WARNING

# Admin superuser — created on first deploy
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=use-a-strong-admin-password
