# ============================================================
# AWS EC2 Production .env  — copy to backend/.env on server
# cp .env.production.example ~/Cloths-by-ASF/backend/.env
# ============================================================

# Django core
SECRET_KEY=replace-with-50-char-random-string
DEBUG=False
ALLOWED_HOSTS=51.20.132.4,afscloths.com,www.afscloths.com
DJANGO_SETTINGS_MODULE=config.settings.production

# Database — SQLite (default, zero-config). Set USE_POSTGRES=True for PostgreSQL.
USE_POSTGRES=False
# DB_NAME=cloth_by_afs
# DB_USER=postgres
# DB_PASSWORD=strong-password
# DB_HOST=localhost
# DB_PORT=5432

# JWT
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# CORS & CSRF
CORS_ALLOWED_ORIGINS=http://51.20.132.4,https://afscloths.com,https://www.afscloths.com
CSRF_TRUSTED_ORIGINS=http://51.20.132.4,https://afscloths.com,https://www.afscloths.com

# Email (Gmail — use App Password)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=amicainternationalservices@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-app-password
DEFAULT_FROM_EMAIL=Cloths by ASF <amicainternationalservices@gmail.com>

# Frontend URL (used in email links)
FRONTEND_URL=https://afscloths.com

# Stripe
STRIPE_PUBLIC_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# S3 media (optional — leave False to store on disk)
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=cloths-by-asf-media
# AWS_S3_REGION_NAME=eu-north-1

# SSL — set True ONLY after certbot HTTPS is working
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Admin superuser (created on first run)
ADMIN_EMAIL=admin@clothsbyasf.com
ADMIN_PASSWORD=replace-with-strong-password

# Logging
DJANGO_LOG_LEVEL=WARNING
